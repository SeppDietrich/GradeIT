// ─── firestore.rules ─────────────────────────────────────────────────────────
// Pune acest fișier în rădăcina proiectului Firebase
// Deploy cu: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Liste private ale utilizatorului ─────────────────────────────────────
    // Doar proprietarul poate citi/scrie listele lui
    match /users/{userId}/gradingLists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Liste publice ─────────────────────────────────────────────────────────
    // Oricine autentificat poate CITI
    // Doar proprietarul (userId stocat în document) poate SCRIE
    match /publicLists/{listId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }
  }
}
